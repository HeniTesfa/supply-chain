# =============================================================================
# .env.example — Environment Variable Reference
# =============================================================================
# Copy this file to the environment-specific .env file and fill in values.
# NEVER commit .env files with real credentials.
#
#   Local : cp .env.example .env.local
#   Dev   : cp .env.example .env.dev
#   Stage : set as GitHub Actions secrets or ECS task definition env vars
#   Prod  : set as GitHub Actions secrets or ECS task definition env vars
#
# Which environments need which variables:
#
#   Variable                  | local | dev | staging | production
#   --------------------------|-------|-----|---------|------------
#   SPRING_PROFILES_ACTIVE    |   ✓   |  ✓  |    ✓    |     ✓
#   ENVIRONMENT               |   ✓   |  ✓  |    ✓    |     ✓
#   SPRING_DATA_MONGODB_URI   |   -   |  -  |    ✓    |     ✓
#   SPRING_KAFKA_BOOTSTRAP_*  |   -   |  -  |    ✓    |     ✓
#   AWS_ACCOUNT_ID            |   ✗   |  ✗  |    ✓    |     ✓
#   AWS_REGION                |   ✗   |  ✗  |    ✓    |     ✓
#   AWS_IAM_ROLE_ARN          |   ✗   |  ✗  |    ✓    |     ✓
#   ECS_CLUSTER_*             |   ✗   |  ✗  |    ✓    |     ✓
#   DATADOG_API_KEY           |   ✗   |  ✗  |    ✓    |     ✓
#   DATADOG_ENABLED           |   ✗   |  ✗  |    ✓    |     ✓
#   DYNATRACE_URI             |   ✗   |  ✗  |    ✓    |     ✓
#   DYNATRACE_API_TOKEN       |   ✗   |  ✗  |    ✓    |     ✓
#   DYNATRACE_ENABLED         |   ✗   |  ✗  |    ✓    |     ✓
#
#   ✓ = needed   ✗ = NOT needed   - = handled by docker-compose automatically
# =============================================================================


# =============================================================================
# COMMON — All environments
# =============================================================================

# Spring Boot active profile: local | dev | staging | production
SPRING_PROFILES_ACTIVE=local

# Environment label used in metrics tags and log fields
ENVIRONMENT=local

# Application version (used in metrics tags)
APP_VERSION=1.0.0


# =============================================================================
# LOCAL & DEV — docker-compose only (set automatically in compose files)
# =============================================================================
# The docker-compose.yml and docker-compose-dev.yml files set these automatically.
# Only override here if you need non-default values.

# MongoDB URI (docker-compose sets this to the local container automatically)
# SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/supply_chain_db

# Kafka bootstrap servers (docker-compose sets this automatically)
# SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092


# =============================================================================
# STAGING & PRODUCTION — AWS (set as GitHub Actions secrets, NOT in this file)
# =============================================================================
# These are configured in: GitHub → Settings → Secrets and variables → Actions
# Do NOT put real values here.

# AWS account number (12 digits)
# AWS_ACCOUNT_ID=

# AWS region (e.g. us-east-1)
# AWS_REGION=

# IAM role ARN for GitHub OIDC authentication
# AWS_IAM_ROLE_ARN=

# ECS cluster names
# ECS_CLUSTER_STAGING=
# ECS_CLUSTER_PRODUCTION=


# =============================================================================
# DATADOG — Staging & Production only (set in ECS task definition env vars)
# =============================================================================

# Enable Datadog metrics export (false in local/dev, true in staging/production)
DATADOG_ENABLED=false

# Datadog API key (get from: app.datadoghq.com → Organization Settings → API Keys)
DATADOG_API_KEY=

# Datadog ingest URL (default works for US1 region)
# EU region: https://api.datadoghq.eu
DATADOG_URI=https://api.datadoghq.com


# =============================================================================
# DYNATRACE — Staging & Production only (set in ECS task definition env vars)
# =============================================================================

# Enable Dynatrace metrics export (false in local/dev, true in staging/production)
DYNATRACE_ENABLED=false

# Dynatrace environment URL
# Format: https://<environment-id>.live.dynatrace.com
DYNATRACE_URI=

# Dynatrace API token with "Ingest metrics" scope
# (Dynatrace console → Access Tokens → Generate new token → metrics.ingest)
DYNATRACE_API_TOKEN=
