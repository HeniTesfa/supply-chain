# =============================================================================
# .gitignore — Supply Chain Microservices System
# Covers: Java/Maven, Spring Boot, React/Node, Docker, Terraform, IDEs, OS
# =============================================================================


# =============================================================================
# JAVA / MAVEN
# =============================================================================

# Compiled class files
*.class

# Package / archive outputs
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

# Maven build output directories (each service has its own target/)
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# Maven wrapper (keep the jar, ignore OS-specific binaries)
.mvn/wrapper/maven-wrapper.properties

# JVM crash logs
hs_err_pid*
replay_pid*


# =============================================================================
# SPRING BOOT
# =============================================================================

# Spring Boot application PID file (created at startup)
*.pid

# Spring Boot DevTools restart trigger file
.reloadtrigger


# =============================================================================
# NODE / REACT
# =============================================================================

# Dependency directories
node_modules/
jspm_packages/

# Build output (React production bundles)
producer-ui/build/
monitoring-ui/build/

# npm / yarn / pnpm lock files and debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/

# Parcel cache
.cache/
.parcel-cache/

# Vite cache
.vite/

# TypeScript build info
*.tsbuildinfo

# Optional npm cache
.npm/

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Test coverage output
coverage/
*.lcov
.nyc_output/

# Storybook build
storybook-static/


# =============================================================================
# DOCKER
# =============================================================================

# Docker override files (local dev only, never commit)
docker-compose.override.yml
docker-compose.local.yml

# Docker context temp files
.dockerignore.local


# =============================================================================
# TERRAFORM
# =============================================================================

# Local .terraform directories (downloaded provider plugins — large, regenerated by init)
**/.terraform/

# Terraform lock file (commit this in real projects to pin provider versions;
# excluded here since no providers are pinned yet)
.terraform.lock.hcl

# Terraform state files (contain sensitive data — use remote state in S3)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan output files (may contain secrets)
*.tfplan

# Variable files that may contain secrets (use -var-file flag instead)
*.tfvars
*.tfvars.json

# Terraform crash log
crash.log
crash.*.log

# Override files (local developer overrides — not for shared use)
override.tf
override.tf.json
*_override.tf
*_override.tf.json


# =============================================================================
# ENVIRONMENT & SECRETS — NEVER COMMIT THESE
# =============================================================================

# Generic .env files
.env
.env.*
!.env.example
!.env.template

# AWS credentials
.aws/
aws-credentials*

# Application secrets
secrets/
*-secrets.yml
*-secrets.yaml
*-secrets.properties

# Kubernetes secrets
*-secret.yaml
*-secret.yml


# =============================================================================
# IDEs
# =============================================================================

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
bin/
!**/src/main/**/bin/
!**/src/test/**/bin/

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# VS Code
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
*~
\#*\#
.\#*


# =============================================================================
# OPERATING SYSTEM
# =============================================================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~


# =============================================================================
# LOGS & RUNTIME ARTIFACTS
# =============================================================================

# Log files (services write to stdout in containers; local logs are noise)
*.log
logs/

# PID files
*.pid
*.seed
*.pid.lock

# Heap dumps and profiler output
*.hprof
*.jfr
*.prof

# JaCoCo coverage reports (generated by mvn test)
**/jacoco.exec
**/jacoco-sessions.exec


# =============================================================================
# CLAUDE CODE (internal tooling)
# =============================================================================
.claude/
